# ---- Core mode ----
# DEMO_MODE=true uses the sample DataHub metadata in sample_data/ instead of
# a real DataHub instance. Set to false once you have real DataHub running.
DEMO_MODE=true

# ---- LLM (used by all agents for reasoning + code generation) ----
LLM_PROVIDER=groq
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Only needed if you switch LLM_PROVIDER=anthropic instead
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ---- DataHub (only needed when DEMO_MODE=false) ----
# INTEGRATION_MODE=mcp uses the DataHub MCP Server (required for hackathon eligibility).
# INTEGRATION_MODE=graphql is a documented fallback only -- do not submit with this alone.
INTEGRATION_MODE=mcp
DATAHUB_GMS_URL=http://localhost:8080
DATAHUB_TOKEN=your_datahub_personal_access_token_here

# ---- DataHub MCP Server (used when INTEGRATION_MODE=mcp) ----
# Launched automatically as a subprocess -- no separate terminal needed.
MCP_SERVER_COMMAND=uvx mcp-server-datahub@latest
# Enables write-back tools (add_tags, update_description, save_document) so the
# Knowledge Agent and GitOps suggestions actually reach DataHub, not just read it.
MCP_ENABLE_MUTATIONS=true

# ---- GitHub (optional: lets the GitOps Agent open real Pull Requests) ----
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=your-username/your-repo-name

# ---- Server ----
PORT=8000
